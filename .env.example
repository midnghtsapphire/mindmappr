# ═══════════════════════════════════════════════════════════════════
# MindMappr Command Center — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Core Application ──────────────────────────────────────────────
PORT=3005
APP_PASSWORD=your_login_password_here

# ── LLM / AI ─────────────────────────────────────────────────────
LLM_API_KEY=sk-or-v1-your_openrouter_key
LLM_MODEL=anthropic/claude-sonnet-4
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key
OPENAI_API_KEY=sk-your_openai_key
CLAUDE_API_KEY=sk-ant-your_claude_key

# ── GitHub ────────────────────────────────────────────────────────
GITHUB_PAT=ghp_your_github_personal_access_token
GITHUB_TOKEN=ghp_your_github_token

# ── DigitalOcean ──────────────────────────────────────────────────
DO_API_TOKEN=dop_v1_your_digitalocean_token

# ── Discord ───────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_server_id

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Google OAuth2 (Drive, Gmail, Docs, Sheets, Calendar) ─────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
GOOGLE_REDIRECT_URI=https://your-app-url/api/google/callback
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SEARCH_CX=your_custom_search_engine_id
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# ── Search ────────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=your_brave_search_key

# ── Media Generation ──────────────────────────────────────────────
LEONARDO_API_KEY=your_leonardo_ai_key
HEYGEN_API_KEY=your_heygen_key
ELEVENLABS_API_KEY=sk_your_elevenlabs_key

# ── PayPal (Digital Arbitrage Academy) ────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_EMAIL=angelreporters@gmail.com

# ── Trading APIs ──────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
COINBASE_API_KEY=your_coinbase_key
COINBASE_API_SECRET=your_coinbase_secret

# ── Social Media APIs ─────────────────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=FreedomAngelCorps
REDDIT_PASSWORD=your_reddit_password
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
YOUTUBE_API_KEY=your_youtube_api_key

# ── Financial Data APIs ───────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
COINGECKO_API_KEY=your_coingecko_key
